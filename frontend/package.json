{
  "name": "jarvis-os",
  "private": true,
  "version": "0.1.0",
  "description": "JARVIS OS — Ambient AI Desktop Assistant",
  "author": "Rajat",
  "main": "electron/main.js",
  "scripts": {
    "dev:vite": "vite",
    "dev:electron": "cross-env NODE_ENV=development electron .",
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"npm run dev:vite\" \"wait-on http://localhost:5173 && npm run dev:electron\"",
    "build": "vite build",
    "build:electron": "npm run build && electron-builder",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "vite": "^8.0.12",
    "vitest": "^4.1.7",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "build": {
    "appId": "com.jarvis.os",
    "productName": "JARVIS OS",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
