# ═══════════════════════════════════════════════════════════
# JARVIS OS — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# ═══════════════════════════════════════════════════════════


# ── AI Provider (Google Gemini — OpenAI-compatible) ────────────────────
# Get key at: https://aistudio.google.com → Get API key
# Free: 1,500 req/day | 1M tokens/day | No credit card
AI_API_KEY=your_gemini_api_key_here
AI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
AI_MODEL=gemini-2.0-flash
# Options: gemini-2.0-flash (fast+free) | gemini-2.5-pro (smarter, paid)
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2048


# ── Wake Word — OpenWakeWord (Phase 2) ──────────────────────
# No account, no API key, no email required.
# Install: pip install openwakeword
# Has built-in 'hey_jarvis' model — works out of the box.
WAKE_WORD=hey_jarvis
# Options: hey_jarvis | alexa | hey_mycroft | (custom trained model path)


# ── Speech-to-Text — Faster Whisper (Phase 2) ────────────────
# No API key needed — runs 100% locally via faster-whisper package
# Just set the model size (base = good balance of speed/accuracy)
STT_MODEL=base
# Options: tiny | base | small | medium | large-v3


# ── Text-to-Speech — Piper TTS (Phase 2) ─────────────────────
# No API key needed — runs 100% locally
# Voice model downloaded automatically on first run
TTS_VOICE=en_US-arctic-medium


# ── App Settings ──────────────────────────────────────────────
DEBUG=true
LOG_LEVEL=DEBUG
# LOG_LEVEL options: DEBUG | INFO | WARNING | ERROR


# ── Observation Mode ──────────────────────────────────────────
# Set to true to enable passive monitoring + pattern detection
OBSERVATION_MODE=false
OBSERVATION_INTERVAL=10


# ── Database ──────────────────────────────────────────────────
# Leave blank to use default SQLite path (recommended for Phase 1-3)
# DB_PATH=backend/data/db/jarvis.db
